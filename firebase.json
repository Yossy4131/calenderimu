{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|js|mjs|wasm|css|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      },
      {
        "source": "**/flutter_service_worker.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "calender-imu",
          "appId": "1:722179987032:android:3b0b356363982450711c2d",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "calender-imu",
          "configurations": {
            "android": "1:722179987032:android:3b0b356363982450711c2d",
            "ios": "1:722179987032:ios:c804cf7d70bd3f59711c2d",
            "macos": "1:722179987032:ios:c804cf7d70bd3f59711c2d",
            "web": "1:722179987032:web:ac31776ea891d484711c2d",
            "windows": "1:722179987032:web:890aaf9cf25c3a7c711c2d"
          }
        }
      }
    }
  }
}
